NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database (Docker local: usar DB_*). En Railway: referencia la variable DATABASE_URL del plugin Postgres.
# DATABASE_URL=postgresql://...
# Si la conexión falla por SSL: DATABASE_SSL=false
DB_HOST=db
DB_PORT=5432
DB_NAME=visitas_db
DB_USER=visitas_admin
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_random_jwt_secret_here
JWT_EXPIRES_IN=8h

# App
APP_NAME=Sistema de Registro de Visitas
COMPANY_NAME=Mi Empresa S.A.
# URL pública base (opcional). Si no se define, los QR usan el Host de cada petición (túnel/LAN).
APP_URL=http://localhost:3000

# Pon 1 si usas Cloudflare Tunnel, nginx u otro proxy delante del contenedor (rate limit e IP real).
# TRUST_PROXY=1

# Email (SMTP) - opcional. Si no se configura, las notificaciones por email se omiten silenciosamente.
# Ejemplo con Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# Ejemplo con Office365: SMTP_HOST=smtp.office365.com  SMTP_PORT=587
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-contrasena-de-aplicacion
# SMTP_FROM=Sistema Visitas <tu-correo@gmail.com>
